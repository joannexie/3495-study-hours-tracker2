<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Show Results - Login</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="card">
    <h1>Show Results</h1>
    <p>Log in to view analytics (reads from MongoDB).</p>

    <% if (error) { %>
      <div class="msg error"><%= error %></div>
    <% } %>

    <form method="POST" action="/login">
      <label>Username</label>
      <input name="username" placeholder="demo" required />

      <label>Password</label>
      <input type="password" name="password" placeholder="pass" required />

      <button type="submit">Login</button>
    </form>

    
  </div>
</body>
</html>
